# Required for password login and encrypted session cookies.
ADMIN_PASSWORD=
AUTH_SECRET=

# Firebase Admin service account — server-side only. Do not commit a JSON key file.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional Cloudinary server credentials for menu image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# Comma-separated browser origins allowed to call the public API.
CORS_ORIGINS=
